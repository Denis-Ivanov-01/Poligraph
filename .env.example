DATABASE_URL=postgresql+psycopg://app_user:password@postgres:5432/politic_bs_filter
REDIS_URL=redis://redis:6379/0

APP_ENV=development
APP_SECRET_KEY=change-this-development-secret
SESSION_COOKIE_NAME=politic_bs_session

ROOT_ADMIN_USERNAME=admin
ROOT_ADMIN_PASSWORD_HASH=plain:admin
ROOT_ADMIN_ENABLED=true

PUBLIC_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
MEDIA_STORAGE_PATH=./media
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Umami analytics
UMAMI_DATABASE_PASSWORD=umami
UMAMI_APP_SECRET=change-this-local-umami-secret
NEXT_PUBLIC_UMAMI_ENABLED=false
NEXT_PUBLIC_UMAMI_SCRIPT_URL=http://localhost:3000/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Internal diagnostics panel
DIAGNOSTICS_PANEL_ENABLED=false
DIAGNOSTICS_PANEL_PATH=/diagnostics_panel
DIAGNOSTICS_DASHBOARD_URL=

VITE_API_BASE_URL=http://localhost:8000/api
VITE_PUBLIC_BASE_URL=http://localhost:5173
